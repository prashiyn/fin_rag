# FinSage RAG — sample environment variables (NO REAL SECRETS)
# Copy to .env and edit: cp .env.example .env

# ---------------------------------------------------------------------------
# Config path (server, scripts)
# ---------------------------------------------------------------------------
# CONFIG_PATH=config/production.yaml

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=6005

# ---------------------------------------------------------------------------
# Auth (overrides config bearer_token if set)
# ---------------------------------------------------------------------------
BEARER_TOKEN=replace_with_dummy_or_real_token

# ---------------------------------------------------------------------------
# Database (overrides config database_url when set)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fin_rag

# ---------------------------------------------------------------------------
# Centralized doc_processing LLM gateway
# All runtime LLM calls in src/ are sent to this service.
# ---------------------------------------------------------------------------
DOC_PROCESSING_BASE_URL=http://127.0.0.1:8001
DOC_PROCESSING_PROVIDER=openai
DOC_PROCESSING_EMBEDDINGS_PROVIDER=openai
# Optional overrides used by specific flows
# FEEDBACK_CLASSIFIER_PROVIDER=openai
# TREERAG_LLM_PROVIDER=openai

# Test-only compatibility var (used by old test scripts)
TEST_LLM_API_KEY=EMPTY

# ---------------------------------------------------------------------------
# Optional: embeddings model name when not provided in config
# ---------------------------------------------------------------------------
EMBEDDINGS_MODEL_NAME=BAAI/bge-m3

# ---------------------------------------------------------------------------
# Optional: provider-specific keys (examples; only used if your code/scripts read them)
# ---------------------------------------------------------------------------
TENCENT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TENCENT_URL=https://api.lkeap.cloud.tencent.com/v1

GROQ_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_URL=https://api.groq.com/v1

