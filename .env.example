# FinSage RAG — environment variables
# Copy to .env and set as needed: cp .env.example .env
# The server and Alembic load .env automatically (python-dotenv). Values here are defaults
# so the app runs without .env. Config (config/production.yaml, config/llm.yaml) is the main
# source; these env vars override or supply values when needed.

# ---------------------------------------------------------------------------
# Config path (server, alembic, scripts)
# If unset: server uses config/production.yaml (relative to project root).
# ---------------------------------------------------------------------------
# CONFIG_PATH=config/production.yaml

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Port for the API server (uv run uvicorn server:app ...). Default 6005.
PORT=6005

# ---------------------------------------------------------------------------
# Auth (overrides config bearer_token if set)
# ---------------------------------------------------------------------------
# BEARER_TOKEN=your_jwt_or_secret_token

# ---------------------------------------------------------------------------
# Database (overrides config database_url when set)
# Used by: server (init_db), alembic (migrations). Same URL for both.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fin_rag

# ---------------------------------------------------------------------------
# Optional: embeddings model name when not provided in config (e.g. QARetriever standalone)
# Main app uses config/llm.yaml → embeddings_model_name.
# ---------------------------------------------------------------------------
# EMBEDDINGS_MODEL_NAME=BAAI/bge-m3

# ---------------------------------------------------------------------------
# Optional: CUDA (server sets CUDA_LAUNCH_BLOCKING=1 by default; uncomment to override)
# ---------------------------------------------------------------------------
# CUDA_LAUNCH_BLOCKING=1
