# FinSage RAG — copy to `.env` and adjust LLM/embeddings URLs as needed.
#
# Repo-root unified compose: Postgres host/user/password/database often mirror `/common/.env`.
# Optional: set `DATABASE_URL` to override the composed URL entirely.

PORT=6005
LOG_LEVEL=INFO
BEARER_TOKEN=replace_with_dummy_or_real_token

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DATABASE=finrag
POSTGRES_MAX_CONNECTIONS=12

CHROMA_SERVER_HOST=chroma
CHROMA_SERVER_PORT=8000
PERSIST_DIRECTORY=./data

DEFAULT_COLLECTION_TOP_K=10
COLLECTIONS_TOP_K=

BM25_STORAGE_BACKEND=local
BM25_LOCAL_BASE_DIR=
BM25_S3_BUCKET=
BM25_S3_PREFIX=
BM25_S3_REGION=

LLM_SERVICE_BASE_URL=http://llm-service:8001
LLM_SERVICE_LLM_ENDPOINT_PATH=/llm/complete
LLM_SERVICE_TIMEOUT_SECONDS=120
LLM_SERVICE_PROVIDER=openai
LLM_SERVICE_EMBEDDINGS_PROVIDER=
LLM_SERVICE_EMBEDDINGS_BATCH_SIZE=64

LLM_MODEL_NAME=Qwen/Qwen2___5-72B-Instruct-AWQ
CHAT_LLM_MODEL_NAME=
EMBEDDINGS_MODEL_NAME=BAAI/bge-m3

RERANK_MODEL=BAAI/bge-reranker-v2-gemma
RERANK_TOPK=5

FEEDBACK_PROCESSING_ENABLED=false
FEEDBACK_PROCESSING_INTERVAL_SECONDS=600
FEEDBACK_LAST_PROCESSED_ID_FILE=log/feedback_last_processed_id.txt
FEEDBACK_CATEGORIES_PATH=config/feedback_categories.json
FEEDBACK_CLASSIFIER_PROVIDER=
FEEDBACK_CLASSIFIER_MODEL=deepseek-v3

TREERAG_ENABLED=false
TREERAG_MAX_DEPTH=2
TREERAG_BRANCHING_FACTOR=3
TREERAG_MAX_WORKERS=6
TREERAG_USE_HYDE=false
TREERAG_RETRIEVE_MAX_CHUNKS=40
TREERAG_SESSION_TTL_SECONDS=1800
TREERAG_LLM_PROVIDER=
TREERAG_LLM_MODEL_NAME=
TREERAG_PLANNER_MODEL=
TREERAG_ANSWER_MODEL=

QA_TABLE_PERSIST_DIRECTORY=./data/qa_chroma
QA_TABLE_DIRECTORY=
FREQUENT_QA_DIRECTORY=

TEST_LLM_BASE_URL=http://127.0.0.1:11434/v1
TEST_LLM_MODEL_NAME=llama3
TEST_LLM_API_KEY=EMPTY
